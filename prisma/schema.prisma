// Prisma schema — HoraDoc
// Datasource: Neon serverless Postgres (pooled URL for the app, direct URL for
// migrations / `prisma db push`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Variables creadas por la integración de Neon en Vercel (prefijo del store).
  //  • *_POSTGRES_PRISMA_URL    → pooled + pgbouncer (runtime de la app)
  //  • *_POSTGRES_URL_NON_POOLING → directa (migraciones / db push)
  url       = env("horadoc_POSTGRES_PRISMA_URL")
  directUrl = env("horadoc_POSTGRES_URL_NON_POOLING")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String
  phone          String?
  especialidad   String?
  registroMedico String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
